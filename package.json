{
  "name": "client-project-tracker",
  "version": "1.0.0",
  "main": "dist/server.js",
  "description": "Portfolio-ready full-stack project tracker with TypeScript, Express, PostgreSQL, React, and AI-assisted task planning.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node tests/run-tests.cjs",
    "client:dev": "node scripts/run-frontend-command.cjs dev",
    "client:build": "node scripts/run-frontend-command.cjs build",
    "client:lint": "node scripts/run-frontend-command.cjs lint",
    "check": "npm run typecheck && npm run build && npm run test && npm run client:lint && npm run client:build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
