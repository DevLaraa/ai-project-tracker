NODE_ENV=development
PORT=3000

# Recommended: single connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/client_project_tracker
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10
AI_PROVIDER=mock
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# Required only when AI_PROVIDER=openai
AI_API_KEY=
AI_REQUEST_TIMEOUT_MS=15000
# Optional: comma-separated list of allowed frontend origins
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional: build DATABASE_URL from parts (if you don't set DATABASE_URL)
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=client_project_tracker


